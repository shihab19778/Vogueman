rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "mdshihabkhandokar786@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ["T-Shirt", "Panjabi", "Polo Shirt", "Pants", "Trousers"] &&
             data.images is list && data.images.size() > 0 &&
             data.sizes is list && data.sizes.size() > 0;
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ["Pending", "Shipped", "Delivered", "Cancelled"] &&
             data.paymentMethod == "COD" &&
             (!('uid' in data) || data.uid == null || (isAuthenticated() && data.uid == request.auth.uid));
    }

    function isValidCoupon(data) {
      return data.code is string && data.code.size() > 0 &&
             data.type in ["percentage", "flat"] &&
             data.value is number && data.value >= 0 &&
             data.active is bool;
    }

    function isValidReview(data) {
      return data.productId is string &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 1000;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() || 
        (isAuthenticated() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'reviewCount']));
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true; // Everyone can read to check validity
      allow create, update: if isAdmin() && isValidCoupon(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /test/{document=**} {
      allow read: if true;
    }
  }
}
